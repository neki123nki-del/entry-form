# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="YOUR_APP_URL"

# GOOGLE_SHEETS_SPREADSHEET_ID: The ID of the Google Sheet to sync with.
# Found in the URL: docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEETS_SPREADSHEET_ID="1Z2nIYNvdPD-mXECDPMnvJ7s_4s1nkTL2y8umZvc6caY"

# SERVICE ACCOUNT CONFIGURATION (Required for Direct Link)
# 1. Create a Service Account at console.cloud.google.com/iam-admin/serviceaccounts
# 2. Add the service account email here:
GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
# 3. Add the private key string here (ensure it includes headers and \n for newlines):
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n..."
