rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Student Rules ---
    match /students/{studentId} {
      // Students are mirrored from Sheets by the backend service account
      // Or by an admin user. For now, let's allow read for all signed in.
      allow read: if isSignedIn();
      allow write: if false; // Only server should write
    }

    // --- Attendance Rules ---
    function isValidAttendance(data) {
      return data.studentId is string && 
             data.status in ['present', 'absent', 'late'] &&
             data.date is string &&
             data.date.size() <= 10;
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn() && resource.data.teacherId == request.auth.uid; // Secure list query
      allow create: if isSignedIn() && isValidAttendance(request.resource.data) && isValidId(attendanceId) && request.resource.data.teacherId == request.auth.uid;
      allow update: if isSignedIn() && isValidAttendance(request.resource.data) && 
                      request.resource.data.teacherId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'notes', 'workSubmission']);
      allow delete: if false;
    }

    // --- Config Rules ---
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
